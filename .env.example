# ================================================================
#   DIỄN ĐÀN SINH VIÊN — Biến Môi Trường
#   Sao chép file này thành .env và điền các giá trị thực
# ================================================================

# ─── URL ─────────────────────────────────────────────────────
FLARUM_BASE_URL=http://localhost

# ─── Database ────────────────────────────────────────────────
DB_ROOT_PASSWORD=password
DB_NAME=flarum_ddsv
DB_USER=flarum
DB_PASSWORD=password

# ─── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=password

# ─── Tài khoản Admin ─────────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASS=password
ADMIN_MAIL=admin@example.com

# ─── Debug (false trong production) ──────────────────────────
FLARUM_DEBUG=false

# ─── Port ────────────────────────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443

# ─── Email (để trống để dùng log driver khi dev) ─────────────
MAIL_DRIVER=log
# MAIL_DRIVER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_SSL=false
# MAIL_ENCRYPTION=tls
# MAIL_USERNAME=your@gmail.com
# MAIL_PASSWORD=your_app_password
# MAIL_FROM=noreply@yourdomain.com
